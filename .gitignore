# Virtual environment
.venv/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Auto-generated version file
rbcopy/_version.py

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Test / coverage
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environment / secrets
.env
.env.*
!.env.example

# Private keys, certificates, and credentials
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.der
credentials.*
config/secrets.*
secrets.*
*_rsa
*_dsa
*_ecdsa
*_ed25519

# Editor
.vscode/
.idea/
*.swp
*.swo

# Robocopy job log files (generated at runtime by rbcopy/logger.py)
robocopy_job_*.log
