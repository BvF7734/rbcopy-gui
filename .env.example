# rbcopy environment configuration
# Copy this file to .env and uncomment / set the values you need.
# .env is listed in .gitignore and will NOT be committed.

# RBCOPY_DATA_DIR — Override the application data directory.
# By default rbcopy stores logs, presets, and preferences in:
#   Windows : %LOCALAPPDATA%\RBCopy
#   Linux / macOS : ~/.rbcopy
# Set this to an absolute path to redirect all persistent data to a
# different location (useful for CI, portable installs, or testing).
#
# RBCOPY_DATA_DIR=C:\Users\you\RBCopy
